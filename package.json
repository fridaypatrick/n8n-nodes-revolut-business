{
  "name": "n8n-nodes-revolut-business",
  "version": "0.0.0-development",
  "description": "n8n community node for Revolut Business webhooks",
  "license": "MIT",
  "homepage": "https://github.com/ppiatkowski/n8n-nodes-revolut-business",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "revolut",
    "revolut-business",
    "webhooks"
  ],
  "author": "Patrick Piatkowski",
  "files": [
    "dist",
    "README.md",
    "scripts/copy-assets.mjs",
    "scripts/generate-certificate.mjs",
    "scripts/revolut-auth.mjs",
    "scripts/simulate-webhook.mjs",
    "scripts/start-tunnel-compose.mjs"
  ],
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "cloudflare:tunnel": "cloudflared tunnel --url http://localhost:5678",
    "clean": "rm -rf dist",
    "dev": "tsc -w -p tsconfig.json",
    "dev:tunnel": "node scripts/start-tunnel-compose.mjs",
    "generate:certificate": "node scripts/generate-certificate.mjs",
    "prepack": "npm run clean && npm run build",
    "release": "semantic-release",
    "revolut:auth": "node scripts/revolut-auth.mjs",
    "simulate:webhook": "node scripts/simulate-webhook.mjs",
    "test": "tsx --test test/**/*.test.ts",
    "test:src": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "n8n-workflow": "^2.31.0"
  },
  "peerDependencies": {
    "n8n-core": "^2.16.1"
  },
  "devDependencies": {
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^12.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "semantic-release": "^25.0.3",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.22.0 <25"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/src/credentials/RevolutBusinessOAuth2Api.credentials.js"
    ],
    "nodes": [
      "dist/src/nodes/RevolutBusinessWebhook/RevolutBusinessWebhook.node.js",
      "dist/src/nodes/RevolutBusinessWebhookTrigger/RevolutBusinessWebhookTrigger.node.js"
    ]
  },
  "volta": {
    "node": "24.15.0"
  }
}
